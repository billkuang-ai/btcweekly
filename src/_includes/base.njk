<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ title }} · BTC Weekly</title>
<meta name="description" content="{{ stories[0].summary | truncate(160) }}">
<meta property="og:title" content="{{ title }}">
<meta property="og:description" content="{{ stories[0].summary | truncate(200) }}">
<meta property="og:url" content="https://btcweekly.org{{ page.url }}">
<meta property="og:type" content="article">
<meta property="og:site_name" content="BTC Weekly">
<meta name="twitter:card" content="summary">
<meta name="twitter:title" content="{{ title }}">
<meta name="twitter:description" content="{{ stories[0].summary | truncate(200) }}">
<link rel="icon" type="image/png" href="/images/logo.png">
<style>
/* Self-hosted fonts */
@font-face {
  font-family: 'Black Han Sans';
  font-style: normal;
  font-weight: 400;
  font-display: swap;
  src: url('/fonts/black-han-sans/black-han-sans-latin-400-normal.woff2') format('woff2');
}
@font-face {
  font-family: 'Inter';
  font-style: normal;
  font-weight: 400;
  font-display: swap;
  src: url('/fonts/inter/inter-latin-400-normal.woff2') format('woff2');
}
@font-face {
  font-family: 'Inter';
  font-style: normal;
  font-weight: 500;
  font-display: swap;
  src: url('/fonts/inter/inter-latin-500-normal.woff2') format('woff2');
}
@font-face {
  font-family: 'Inter';
  font-style: normal;
  font-weight: 600;
  font-display: swap;
  src: url('/fonts/inter/inter-latin-600-normal.woff2') format('woff2');
}
@font-face {
  font-family: 'Inter';
  font-style: normal;
  font-weight: 700;
  font-display: swap;
  src: url('/fonts/inter/inter-latin-700-normal.woff2') format('woff2');
}

:root {
  --orange:        #F7931A;
  --orange-bright: #FFAA3A;
  --orange-soft:   #FFBE5C;
  --orange-mist:   #FFD48C;
  --orange-pale:   #FFE8BE;
  --orange-faint:  #FFF5E6;

  --bg:            #FFF6EC;
  --white:         #FFFFFF;
  --surface-soft:  #FFF9F2;
  --border:        #EDDECC;
  --border-soft:   #F5E9D8;

  --text:          #1C1208;
  --muted:         #52402C;
  --faint:         #A08060;

  --shadow-sm:   0 1px 3px rgba(247,147,26,0.08), 0 1px 8px rgba(247,147,26,0.05);
  --shadow-lead: 0 2px 0 var(--orange-pale), 0 6px 24px rgba(247,147,26,0.12);

  --text-label: clamp(12px, 1.8vw, 13px);
  --text-meta:  clamp(13px, 2vw,   14px);
  --text-body:  clamp(15px, 2.2vw, 16px);
  --text-title: clamp(17px, 2.6vw, 18px);
  --text-lead:  clamp(20px, 3.2vw, 22px);
  --text-num:   clamp(24px, 3.8vw, 28px);
  --text-mark:  clamp(32px, 12vw,  96px);
}

*,*::before,*::after { box-sizing:border-box; margin:0; padding:0; }
html { -webkit-font-smoothing:antialiased; text-rendering:optimizeLegibility; }
body {
  font-family:'Inter',sans-serif; background:var(--bg);
  color:var(--text); font-size:var(--text-body);
  line-height:1.65; min-height:100vh;
}
a { color:var(--orange); text-decoration:none; transition:color 150ms; }
a:hover { color:var(--orange-bright); text-decoration:underline; }

.wrapper { max-width:660px; margin:0 auto; padding:0 20px 72px; }

/* ── TOP BAR ── */
.top-bar {
  background:var(--orange); padding:10px 20px; margin:0 -20px;
  display:flex; align-items:center; justify-content:space-between;
  box-shadow:0 3px 0 var(--orange-bright);
}
.top-bar-tagline { font-size:var(--text-label); font-weight:600; color:rgba(255,255,255,0.76); letter-spacing:0.06em; white-space:nowrap; }
.top-bar-tagline .hi { color:#fff; font-weight:700; }
.top-bar-logo { height:28px; width:auto; flex-shrink:0; }
.top-bar-spacer { width:28px; flex-shrink:0; }

/* ── WORDMARK ── */
.masthead-hero { padding:36px 0 0; }
.footer-logo { height:auto; width:180px; display:block; margin:12px auto 4px; }
.wordmark {
  font-family:'Black Han Sans',sans-serif;
  font-size:var(--text-mark); line-height:0.88; letter-spacing:0.02em; display:block;
  white-space:nowrap;
}
.w1 {
  color:var(--orange);
  text-shadow:2px 2px 0 var(--orange-bright),4px 4px 0 var(--orange-soft),6px 6px 0 var(--orange-mist);
}
.w2 {
  color:var(--text);
  -webkit-text-stroke:1.5px var(--orange);
  text-shadow:3px 3px 0 var(--orange-pale),5px 5px 0 var(--orange-mist);
}

/* ── META ROW ── */
.meta-row {
  display:flex; align-items:center; justify-content:center;
  margin-top:16px; padding:13px 0;
}
.issue-pill {
  background:var(--white); color:var(--orange);
  font-size:var(--text-label); font-weight:700; letter-spacing:0.1em; text-transform:uppercase;
  padding:6px 16px; border-radius:4px; white-space:nowrap;
  border:1.5px solid var(--orange); box-shadow:2px 2px 0 var(--orange-pale);
}

.sponsor { display:none; }

/* ── STORY CARD ── */
.story {
  display:flex; flex-direction:column;
  background:var(--white); border:1px solid var(--border);
  border-radius:10px; margin-top:10px;
  box-shadow:var(--shadow-sm);
  overflow:hidden;
}

/* Story #1 elevated */
.story.s1 {
  border-top:4px solid var(--orange);
  box-shadow:var(--shadow-lead);
}

@media (hover: hover) and (pointer: fine) {
  .story:hover    { border-color:var(--orange-soft); }
  .story.s1:hover { border-color:var(--orange-soft); border-top-color:var(--orange); }
}

/* ── STORY META BAR ── */
.story-meta {
  display:flex; align-items:center; gap:7px;
  padding:7px 16px;
  background:var(--surface-soft);
  border-bottom:1px solid var(--border-soft);
}
.story.s1 .story-meta {
  background:var(--orange-faint);
  border-bottom-color:var(--orange-pale);
}

.s-n {
  font-family:'Black Han Sans',sans-serif;
  font-size:var(--text-meta); line-height:1;
  color:var(--orange);
}

.s-meta-sep {
  color:var(--orange-soft);
  font-size:var(--text-label);
  line-height:1;
}

.s-cat {
  font-size:var(--text-label); font-weight:700; letter-spacing:0.14em; text-transform:uppercase;
  color:var(--orange);
}

/* ── STORY BODY ── */
.story-body { padding:16px 18px; }

.s-title { font-size:var(--text-title); font-weight:700; color:var(--text); line-height:1.32; }

.s-summary { font-size:var(--text-body); color:var(--muted); line-height:1.62; margin-top:7px; }
.s-source {
  margin-top:10px; padding-top:10px; border-top:1px solid var(--border-soft);
  font-size:var(--text-meta); color:var(--faint); display:flex; align-items:center; gap:5px; flex-wrap:wrap;
}
.s-source a { color:var(--orange); font-weight:500; }

/* ── RSS ── */
.rss {
  margin:28px 0 24px; background:var(--white);
  border:1px solid var(--border); border-radius:10px;
  padding:20px 22px; display:flex; align-items:center; gap:16px;
  box-shadow:var(--shadow-sm);
}
.rss-icon {
  width:42px; height:42px; background:var(--orange); color:#fff;
  border-radius:8px; display:flex; align-items:center; justify-content:center;
  flex-shrink:0; box-shadow:2px 2px 0 var(--orange-bright),3px 3px 0 var(--orange-soft);
}
.rss-title { font-size:var(--text-title); font-weight:700; color:var(--text); margin-bottom:3px; }
.rss-sub   { font-size:var(--text-body); color:var(--muted); }
.rss-link  { display:inline-block; margin-top:6px; color:var(--orange); font-weight:700; font-size:var(--text-meta); }
.rss-link:hover { color:var(--orange-bright); }

/* ── FOOTER ── */
.footer {
  text-align:center; padding:24px 0; border-top:1px solid var(--border-soft);
  font-size:var(--text-meta); color:var(--faint); line-height:2;
}
.footer a { color:var(--orange); }
.footer a:hover { color:var(--orange-bright); }

/* ── PREV / NEXT NAV ── */
.issue-nav {
  display:flex; justify-content:space-between; align-items:center;
  margin-top:28px;
}
.issue-nav a {
  display:flex; align-items:center; justify-content:center;
  width:40px; height:40px; border-radius:50%;
  background:var(--white); border:1.5px solid var(--border);
  color:var(--orange); font-size:18px; line-height:1;
  box-shadow:var(--shadow-sm); transition:border-color 150ms, box-shadow 150ms;
  text-decoration:none;
}
.issue-nav a:hover {
  border-color:var(--orange-soft);
  box-shadow:2px 2px 0 var(--orange-pale), var(--shadow-sm);
  text-decoration:none;
}
.issue-nav .spacer { width:40px; }

@media(max-width:480px){
  .meta-row { flex-direction:column; align-items:flex-start; gap:8px; }
  .rss { flex-direction:column; align-items:flex-start; }
}

/* ── EDITOR'S CHOICE CARD ── */
.ec-card {
  margin-top:10px;
  background:var(--orange-faint);
  border:1px solid var(--border);
  border-radius:10px;
  overflow:hidden;
  box-shadow:var(--shadow-sm);
}
.ec-label {
  padding:7px 16px;
  background:var(--surface-soft);
  border-bottom:1px solid var(--border-soft);
  font-size:var(--text-label);
  font-weight:700;
  letter-spacing:0.1em;
  text-transform:uppercase;
  color:var(--faint);
}
.ec-grid {
  display:grid;
  grid-template-columns:1fr 1fr;
}
.ec-col {
  padding:14px 16px;
  background:var(--orange-faint);
}
.ec-col:first-child {
  border-right:1px solid var(--border-soft);
}
.ec-cat {
  font-size:var(--text-label);
  font-weight:700;
  letter-spacing:0.14em;
  text-transform:uppercase;
  color:var(--orange);
  margin-bottom:4px;
}
.ec-title {
  font-size:var(--text-meta);
  font-weight:700;
  color:var(--text);
  line-height:1.3;
  margin-bottom:6px;
}
.ec-copy {
  font-size:var(--text-meta);
  color:var(--muted);
  line-height:1.55;
}
.ec-cta {
  display:inline-block;
  margin-top:8px;
  font-size:var(--text-label);
  font-weight:700;
  color:var(--orange);
}
.ec-cta:hover { color:var(--orange-bright); }
.ec-disclosure {
  padding:8px 16px;
  border-top:1px solid var(--border-soft);
  font-size:11px;
  color:var(--faint);
  background:var(--surface-soft);
}
@media(max-width:480px) {
  .ec-grid { grid-template-columns:1fr; }
  .ec-col:first-child { border-right:none; border-bottom:1px solid var(--border-soft); }
}
</style>
</head>
<body>
<div class="wrapper">

  <header>
    <div class="top-bar">
      <img src="/images/logo.png" class="top-bar-logo" alt="BTC Weekly">
      <div class="top-bar-tagline"><span class="hi">B</span>alanced · <span class="hi">T</span>rusted · <span class="hi">C</span>oncise</div>
      <div class="top-bar-spacer"></div>
    </div>
    <div class="masthead-hero">
      <div class="wordmark"><span class="w1">BTC</span>&thinsp;<span class="w2">WEEKLY</span></div>
      <div class="meta-row">
        <div class="issue-pill">Week {{ week }} · {{ dateRange }}</div>
      </div>
    </div>
  </header>

  <div class="sponsor"><!-- sponsor placeholder --></div>

  {% for story in stories %}
  <div class="story{% if loop.first %} s1{% endif %}">
    <div class="story-meta">
      <span class="s-n">{{ loop.index }}</span>
      <span class="s-meta-sep">·</span>
      <span class="s-cat">{{ story.category }}</span>
    </div>
    <div class="story-body">
      <div class="s-title">{{ story.title }}</div>
      <div class="s-summary">{{ story.summary }}</div>
      <div class="s-source">
        ({% for src in story.sources %}<a href="{{ src.url }}">{{ src.label }}</a>{% if not loop.last %}, {% endif %}{% endfor %})
      </div>
    </div>
  </div>
  {% endfor %}

  <div class="ec-card">
    <div class="ec-label">Editor's Choice</div>
    <div class="ec-grid">
      <div class="ec-col">
        <div class="ec-cat">🔑 Hardware</div>
        <div class="ec-title">Bitkey Bitcoin Hardware Wallet</div>
        <p class="ec-copy">Self-custody made simple. Built by Block, Jack Dorsey's company, for real-world Bitcoin storage and everyday use.</p>
        <a href="https://amzn.to/4dHllLf" class="ec-cta">View on Amazon →</a>
      </div>
      <div class="ec-col">
        <div class="ec-cat">☕ Coffee</div>
        <div class="ec-title">Bean of Fire Exotic Variety Box</div>
        <p class="ec-copy">Exotic single-origin coffees created by Nayib Bukele — the president who made El Salvador the first nation to adopt Bitcoin as legal tender.</p>
        <a href="https://amzn.to/41wynUA" class="ec-cta">View on Amazon →</a>
      </div>
    </div>
    <div class="ec-disclosure">Amazon affiliate links. Purchases support BTC Weekly.</div>
  </div>

  {% if prevIssue or nextIssue %}
  <nav class="issue-nav">
    {% if prevIssue %}<a href="{{ prevIssue.url }}" title="← Older">←</a>{% else %}<span class="spacer"></span>{% endif %}
    {% if nextIssue %}<a href="{{ nextIssue.url }}" title="Newer →">→</a>{% else %}<span class="spacer"></span>{% endif %}
  </nav>
  {% endif %}

  <div class="rss">
    <div class="rss-icon">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1" fill="currentColor"/></svg>
    </div>
    <div>
      <div class="rss-title">Follow via RSS</div>
      <div class="rss-sub">Your weekly roundup of Bitcoin's key developments. New issue every Saturday night.</div>
      <a href="/feed.xml" class="rss-link">btcweekly.org/feed.xml →</a>
    </div>
  </div>

  <footer class="footer">
    <div><a href="https://btcweekly.org">btcweekly.org</a> · <a href="/archive/">Archive</a> · <a href="/feed.xml">RSS</a></div>
    <img src="/images/logo.png" class="footer-logo" alt="BTC Weekly">
    <div>© 2026 BTC Weekly · Not financial advice</div>
  </footer>
</div>
</body>
</html>
